{
  "extends": ["next/core-web-vitals", "next/typescript"],
  "plugins": ["import", "@typescript-eslint"],
  "rules": {
    "max-len": ["warn", { "code": 80, "ignoreUrls": true, "ignoreStrings": true, "ignoreTemplateLiterals": true, "ignoreRegExpLiterals": true }],
    "max-lines": ["warn", { "max": 50, "skipBlankLines": true, "skipComments": true }],
    "no-unreachable": "error",
    "no-constant-condition": "warn",
    "no-unused-expressions": "warn",

    "no-restricted-syntax": [
      "error",
      {
        "selector": "CallExpression[callee.object.name='document'][callee.property.name=/^(querySelector|getElementById|getElementsBy)/]",
        "message": "No imperative DOM queries. Use React refs or state instead."
      }
    ],

    "no-restricted-imports": [
      "error",
      {
        "paths": [
          {
            "name": "@mui/material",
            "message": "Import from '@mui/material/ComponentName' for tree-shaking (e.g., '@mui/material/Box')."
          },
          {
            "name": "@mui/icons-material",
            "message": "Import from '@mui/icons-material/IconName' for tree-shaking."
          },
          {
            "name": "react-redux",
            "importNames": ["useSelector", "useDispatch"],
            "message": "Use typed hooks: useAppSelector / useAppDispatch from '@/store/hooks'."
          },
          {
            "name": "axios",
            "message": "Use apiClient from '@/lib/apiClient' — no direct axios imports."
          }
        ]
      }
    ],

    "import/order": [
      "warn",
      {
        "groups": ["builtin", "external", "internal", "parent", "sibling", "index"],
        "pathGroups": [
          { "pattern": "react", "group": "external", "position": "before" },
          { "pattern": "next/**", "group": "external", "position": "before" },
          { "pattern": "@mui/**", "group": "external", "position": "after" },
          { "pattern": "@/**", "group": "internal", "position": "before" }
        ],
        "pathGroupsExcludedImportTypes": ["builtin"],
        "newlines-between": "never",
        "alphabetize": { "order": "asc", "caseInsensitive": true }
      }
    ],

    "@typescript-eslint/no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],

    "@typescript-eslint/consistent-type-imports": [
      "warn",
      { "prefer": "type-imports", "fixStyle": "inline-type-imports" }
    ],

    "react/jsx-no-literals": ["warn", {
      "noStrings": true,
      "ignoreProps": true,
      "noAttributeStrings": false
    }]
  },
  "overrides": [
    {
      "files": ["src/store/slices/*.ts", "src/types/*.ts", "src/lib/codeTemplates.ts", "src/lib/scaffolder/**/*.ts"],
      "rules": { "max-lines": "off" }
    },
    {
      "files": ["src/lib/apiClient.ts"],
      "rules": { "no-restricted-imports": "off", "max-lines": "off" }
    },
    {
      "files": ["src/store/hooks.ts"],
      "rules": { "no-restricted-imports": "off" }
    },
    {
      "files": ["src/components/content/*.tsx"],
      "rules": {
        "react/jsx-no-literals": "off"
      }
    },
    {
      "files": ["*.test.ts", "*.test.tsx", "*.spec.ts"],
      "rules": {
        "max-lines": "off",
        "react/jsx-no-literals": "off"
      }
    }
  ]
}
