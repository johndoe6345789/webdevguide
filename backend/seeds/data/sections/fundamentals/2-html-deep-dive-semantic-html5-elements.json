{
  "type": "accordion",
  "title": "Semantic HTML5 Elements",
  "blocks": [
    {
      "type": "text",
      "body": "Semantic elements describe what they contain, not how they look. A `<nav>` tag tells browsers, screen readers, and search engines that the content inside is navigation. A `<div>` says nothing. Using semantic HTML improves accessibility, SEO, and code readability."
    },
    {
      "type": "code",
      "language": "html",
      "filename": "semantic-layout.html",
      "code": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>My Site</title>\n</head>\n<body>\n  <header>\n    <nav>\n      <a href=\"/\">Home</a>\n      <a href=\"/about\">About</a>\n      <a href=\"/contact\">Contact</a>\n    </nav>\n  </header>\n\n  <main>\n    <article>\n      <h1>Understanding Semantic HTML</h1>\n      <time datetime=\"2025-01-15\">January 15, 2025</time>\n\n      <section>\n        <h2>Why It Matters</h2>\n        <p>Semantic elements give meaning to your content.</p>\n        <figure>\n          <img src=\"/diagram.png\" alt=\"HTML document structure diagram\">\n          <figcaption>A typical semantic HTML document structure.</figcaption>\n        </figure>\n      </section>\n\n      <aside>\n        <h3>Related Articles</h3>\n        <ul>\n          <li><a href=\"/css-basics\">CSS Basics</a></li>\n        </ul>\n      </aside>\n    </article>\n  </main>\n\n  <footer>\n    <p>&copy; 2025 My Site. All rights reserved.</p>\n  </footer>\n</body>\n</html>"
    },
    {
      "type": "table",
      "heading": "Key semantic elements",
      "headers": [
        "Element",
        "Purpose",
        "Replaces"
      ],
      "rows": [
        [
          "<header>",
          "Introductory content, site banner, or section header",
          "<div class=\"header\">"
        ],
        [
          "<nav>",
          "Navigation links",
          "<div class=\"nav\">"
        ],
        [
          "<main>",
          "Primary content of the page (only one per page)",
          "<div class=\"main\">"
        ],
        [
          "<article>",
          "Self-contained, independently distributable content",
          "<div class=\"post\">"
        ],
        [
          "<section>",
          "Thematic grouping of content with a heading",
          "<div class=\"section\">"
        ],
        [
          "<aside>",
          "Tangentially related content (sidebars, callouts)",
          "<div class=\"sidebar\">"
        ],
        [
          "<footer>",
          "Footer for the page or a section",
          "<div class=\"footer\">"
        ],
        [
          "<figure> / <figcaption>",
          "Self-contained media with an optional caption",
          "<div class=\"image-wrapper\">"
        ],
        [
          "<time>",
          "Machine-readable date/time",
          "<span class=\"date\">"
        ],
        [
          "<mark>",
          "Highlighted or relevant text",
          "<span class=\"highlight\">"
        ]
      ]
    }
  ]
}
